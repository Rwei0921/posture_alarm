[Unit]
Description=Posture Alarm Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/posture_alarm
Environment=PYTHONUNBUFFERED=1
Environment=SHOW_WINDOW=0
Environment=CAMERA_BACKEND=rpicam
Environment=CAMERA_WIDTH=640
Environment=CAMERA_HEIGHT=480
ExecStart=/home/pi/posture_alarm/.venv/bin/python /home/pi/posture_alarm/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
