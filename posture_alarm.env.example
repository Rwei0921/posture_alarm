# Copy this file to /etc/posture_alarm.env on Raspberry Pi and fill real values.
# Do not commit the filled production file.

LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=
DISCORD_WEBHOOK_URL=

LOG_FILE_ENABLED=1
LOG_FILE_PATH=/home/pi/posture_alarm/data/posture_alarm.log

SIMULATE_GPIO=0
BUZZER_PWM_ENABLED=1
BUZZER_PWM_FREQUENCY=2000
